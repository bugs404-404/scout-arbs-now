# Same-origin: nginx in the dashboard container reverse-proxies /api and
# /ws to the backend. Leave these empty so the SPA derives URLs from
# window.location at runtime — works on localhost, LAN, AND any public
# tunnel hostname without rebuilds.
#
# For local dev with `npm run dev` (frontend on :8080, backend on :8000),
# create a .env.local with:
#   VITE_API_URL=http://localhost:8000
#   VITE_WS_URL=ws://localhost:8000/ws/arbs
VITE_API_URL=
VITE_WS_URL=
